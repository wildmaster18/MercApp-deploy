<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark">
                <h4 class="mb-0">
                    <i class="bi bi-pencil-square me-2"></i>Editar Producto
                </h4>
            </div>
            <div class="card-body">

                {{> mensajeError}}

                <form action="/productos/editar/{{producto._id}}" method="POST" enctype="multipart/form-data">

                    <div class="mb-3">
                        <label for="nombre" class="form-label fw-semibold">
                            Nombre del producto <span class="text-danger">*</span>
                        </label>
                        <input type="text"
                               id="nombre"
                               name="nombre"
                               class="form-control"
                               value="{{producto.nombre}}">
                    </div>

                    <div class="mb-3">
                        <label for="precio" class="form-label fw-semibold">
                            Precio (USD) <span class="text-danger">*</span>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number"
                                   id="precio"
                                   name="precio"
                                   class="form-control"
                                   step="0.01"
                                   min="0"
                                   value="{{producto.precio}}">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="descripcion" class="form-label fw-semibold">
                            Descripción
                        </label>
                        <textarea id="descripcion"
                                  name="descripcion"
                                  class="form-control"
                                  rows="3">{{producto.descripcion}}</textarea>
                    </div>

                    <div class="mb-3">
                        <label for="stock" class="form-label fw-semibold">
                            Stock disponible
                        </label>
                        <input type="number"
                               id="stock"
                               name="stock"
                               class="form-control"
                               min="0"
                               value="{{producto.stock}}">
                    </div>

                    <div class="mb-3">
                        <label for="categoryId" class="form-label fw-semibold">
                            Categoría <span class="text-danger">*</span>
                        </label>
                        <select id="categoryId" name="categoryId" class="form-select">
                            {{#each categorias}}
                                <option value="{{this.idCat}}" {{#siIgual this.idCat ../producto.categoryId}}selected{{/siIgual}}>
                                    {{this.nombre}}
                                </option>
                            {{/each}}
                        </select>
                    </div>

                    {{#if producto.imagen}}
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Imagen actual</label>
                            <div>
                                <img src="/uploads/{{producto.imagen}}"
                                     alt="{{producto.nombre}}"
                                     class="img-thumbnail"
                                     style="height: 120px; object-fit: cover;">
                            </div>
                        </div>
                    {{/if}}

                    <div class="mb-4">
                        <label for="imagen" class="form-label fw-semibold">
                            {{#if producto.imagen}}Cambiar imagen{{else}}Agregar imagen{{/if}}
                        </label>
                        <input type="file"
                               id="imagen"
                               name="imagen"
                               class="form-control"
                               accept="image/jpeg, image/png, image/gif">
                        <div class="form-text">Deja vacío para mantener la imagen actual.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning flex-grow-1">
                            <i class="bi bi-save me-1"></i>Actualizar producto
                        </button>
                        <a href="/productos" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
